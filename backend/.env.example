# Copy this file to ".env" and adjust values.
DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave DATABASE_URL empty to use a local SQLite file (zero setup).
# For PostgreSQL (used by Docker), use this format:
# DATABASE_URL=postgres://cpuser:cppass@db:5432/cpinsight
DATABASE_URL=

CORS_ALLOW_ALL=True
CODEFORCES_API_BASE=https://codeforces.com/api
